<%
  const categoriesRepo = process.mainModule.require(process.cwd() + '/server/repositories/categories');
  const activeCategories = categoriesRepo.listActive();
%>
<%- include('../partials/header') %>

<!-- Hero Section with Floating Organic Elements -->
<section class="hero">
  <div class="hero-floating-elements">
    <span class="floating-item fi-1">🥜</span>
    <span class="floating-item fi-2">🍎</span>
    <span class="floating-item fi-3">🌿</span>
    <span class="floating-item fi-4">☕</span>
  </div>
  <div class="container">
    <h1>Taptaze, <span class="hero-highlight">Doğal</span> ve Kapınızda</h1>
    <p>Günlük kavrulmuş kuruyemişler, özenle kurutulmuş meyveler ve katkısız organik atıştırmalıklar. Doğanın en taze lezzetlerini sofranıza getiriyoruz.</p>
    <div class="hero-actions">
      <a href="#kategoriler" class="btn btn-accent">Kategorileri Keşfet</a>
      <a href="/urunler" class="btn btn-outline">Tüm Ürünler →</a>
    </div>
  </div>
</section>

<!-- Trust Badges -->
<section class="trust-strip">
  <div class="container">
    <div class="trust-badges">
      <div class="trust-badge">
        <div class="trust-badge-icon">🌿</div>
        <span>%100 Doğal Ürünler</span>
      </div>
      <div class="trust-badge">
        <div class="trust-badge-icon">🔥</div>
        <span>Günlük Kavrulmuş</span>
      </div>
      <div class="trust-badge">
        <div class="trust-badge-icon">🚚</div>
        <span>Hızlı Teslimat</span>
      </div>
      <div class="trust-badge">
        <div class="trust-badge-icon">✨</div>
        <span>Tazelik Garantisi</span>
      </div>
    </div>
  </div>
</section>

<!-- Bento Grid Category Section -->
<section id="kategoriler" class="bento-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title reveal">Lezzet Kategorileri</h2>
      <p class="section-sub reveal">Özenle seçilmiş, taptaze ve katkısız premium ürün gruplarımız</p>
    </div>
    
    <div class="bento-grid reveal stagger-1">
      <% 
        const categoryMeta = {
          'kuruyemis': { emoji: '🥜', label: 'Taptaze Kavrulmuş', featured: true },
          'kuru-meyve': { emoji: '🍎', label: '%100 Doğal', featured: false },
          'organik-urunler': { emoji: '🌿', label: 'Katkısız Organik', featured: false },
          'lokum-sekerleme': { emoji: '🍬', label: 'Geleneksel', featured: false },
          'kahve-cay': { emoji: '☕', label: 'Aromatik', featured: false },
          'baharatlar': { emoji: '🌶️', label: 'Taze Çekilmiş', featured: true },
          'yaglar-soslar': { emoji: '🍯', label: 'Soğuk Sıkım', featured: false },
          'ballar-receller': { emoji: '🐝', label: 'Doğal & Saf', featured: false },
          'draje-cikolata': { emoji: '🍫', label: 'Premium Draje', featured: false },
          'bitkisel-urunler': { emoji: '🌱', label: 'Şifalı Destek', featured: false }
        };
        
        activeCategories.forEach((cat, index) => {
          const meta = categoryMeta[cat.slug] || { emoji: '✨', label: 'Doğal Lezzet', featured: false };
      %>
        <a href="/urunler?kategori=<%= cat.slug %>" class="bento-card <%= meta.featured ? 'featured' : '' %>">
          <div class="bento-arrow">→</div>
          <div class="bento-emoji"><%= meta.emoji %></div>
          <div>
            <span class="bento-label"><%= meta.label %></span>
            <h3><%= cat.name %></h3>
            <p class="bento-desc"><%= cat.description %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- Featured Products Section -->
<section id="urunler" style="background: var(--bg-warm); padding: 5.5rem 0;">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title reveal">Öne Çıkan Ürünler</h2>
      <p class="section-sub reveal">Müşterilerimizin en çok tercih ettiği taptaze lezzetlerimiz</p>
    </div>
    
    <div class="product-grid reveal stagger-1">
      <% featuredProducts.forEach(function(p) { %>
        <article class="product-card">
          <a href="/urun/<%= p.slug %>">
            <div class="product-card-image">
              <% if (p.discount_percent > 0) { %><span class="badge-discount">%<%= p.discount_percent %> İndirim</span><% } %>
              <% if (p.stock <= 0) { %><span class="badge-soldout">TÜKENDİ</span><% } %>
              <% if (p.image_path) { %>
                <img src="<%= p.image_path %>" alt="<%= p.title %>" loading="lazy">
              <% } else { %>
                <div class="product-placeholder">🥜</div>
              <% } %>
            </div>
            <div class="product-card-body">
              <h3 class="product-card-title"><%= p.title %></h3>
              <div class="product-price">
                <span class="price-current"><%= formatPrice(p.sale_price || p.price) %></span>
                <% if (p.sale_price) { %><span class="price-old"><%= formatPrice(p.price) %></span><% } %>
                <span class="price-unit">/ kg</span>
              </div>
            </div>
          </a>
          <div class="product-card-body product-card-actions">
            <button type="button" class="btn-add" data-add-cart="<%= p.id %>" data-title="<%= p.title %>" data-price="<%= p.sale_price || p.price %>" data-slug="<%= p.slug %>" <%= p.stock <= 0 ? 'disabled' : '' %>>
              <%= p.stock <= 0 ? 'Tükendi' : '🛒 Sepete Ekle' %>
            </button>
          </div>
        </article>
      <% }) %>
    </div>
    
    <p style="text-align:center; margin-top:3.5rem;" class="reveal">
      <a href="/urunler" class="btn btn-primary">Tüm Ürünleri Gör →</a>
    </p>
  </div>
</section>

<%- include('../partials/footer') %>
