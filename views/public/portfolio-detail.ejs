<%- include('../partials/header') %>

<div class="container">
  <article class="portfolio-detail-container">
    <!-- Left Sidebar (Sticky details) -->
    <aside class="portfolio-sidebar">
      <% if (org.category_name) { %>
        <span class="portfolio-tag"><%= org.category_name %></span>
      <% } %>
      
      <h1 style="font-size:1.8rem; line-height:1.3; margin: 0.5rem 0 1rem; font-weight: 700;"><%= org.title %></h1>
      
      <% if (org.location || org.event_date) { %>
        <div class="portfolio-meta-info">
          <% if (org.location) { %>
            <div class="portfolio-meta-item">
              <span>📍</span> <span><%= org.location %></span>
            </div>
          <% } %>
          <% if (org.event_date) { %>
            <div class="portfolio-meta-item">
              <span>📅</span> <span><%= org.event_date %></span>
            </div>
          <% } %>
        </div>
      <% } %>
      
      <% if (org.description) { %>
        <div class="portfolio-desc-text">
          <p><%= org.description %></p>
        </div>
      <% } %>
      
      <div class="portfolio-sidebar-actions">
        <a href="https://wa.me/<%= settings?.contact_whatsapp %>?text=<%= encodeURIComponent('Merhaba, ' + org.title + ' özel paketi / sunumu hakkında bilgi almak ve sipariş vermek istiyorum.') %>" class="btn btn-whatsapp btn-block" target="_blank" rel="noopener">
          Sipariş Ver / Bilgi Al
        </a>
        <a href="/gerceklestirdigimiz-isler" class="btn btn-outline-dark btn-block">
          ← Tüm Paket & Sunumlar
        </a>
      </div>
    </aside>

    <!-- Right Column (Image Gallery Grid) -->
    <section class="portfolio-gallery-column">
      <% if (org.images && org.images.length) { %>
        <div class="portfolio-dense-grid">
          <% org.images.forEach(function(img, index) { %>
            <div class="portfolio-gallery-item" data-index="<%= index %>" data-path="<%= img.path %>" data-caption="<%= img.caption || '' %>">
              <img src="<%= img.path %>" alt="<%= img.caption || org.title %>" loading="lazy">
              <div class="portfolio-item-overlay">
                <div class="portfolio-overlay-icon">
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7" />
                  </svg>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state" style="background:var(--white); border:1px solid var(--border); border-radius:var(--radius)">
          <p>Bu özel pakete/sunuma ait henüz görsel eklenmemiş.</p>
        </div>
      <% } %>
    </section>
  </article>
</div>

<!-- Premium Lightbox Modal -->
<div id="lightbox" class="lightbox-modal" aria-hidden="true">
  <button class="lightbox-close" id="lightboxClose" aria-label="Kapat" title="Kapat (ESC)">&times;</button>
  <button class="lightbox-arrow lightbox-prev" id="lightboxPrev" aria-label="Önceki Görsel" title="Önceki (Sol Ok)">&#10094;</button>
  <div class="lightbox-content" id="lightboxContent">
    <img id="lightboxImg" src="" alt="">
    <div id="lightboxCaption" class="lightbox-caption"></div>
  </div>
  <button class="lightbox-arrow lightbox-next" id="lightboxNext" aria-label="Sonraki Görsel" title="Sonraki (Sağ Ok)">&#10095;</button>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const galleryItems = document.querySelectorAll('.portfolio-gallery-item');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightboxImg');
  const lightboxContent = document.getElementById('lightboxContent');
  const lightboxCaption = document.getElementById('lightboxCaption');
  const lightboxClose = document.getElementById('lightboxClose');
  const lightboxPrev = document.getElementById('lightboxPrev');
  const lightboxNext = document.getElementById('lightboxNext');
  
  if (!galleryItems.length) return;
  
  // Parse all images into an array for easy navigation
  const images = Array.from(galleryItems).map(item => ({
    path: item.dataset.path,
    caption: item.dataset.caption
  }));
  
  let currentIndex = 0;
  
  function openLightbox(index) {
    currentIndex = index;
    updateLightboxContent();
    lightbox.classList.add('open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden'; // Lock background scrolling
  }
  
  function closeLightbox() {
    lightbox.classList.remove('open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = ''; // Unlock background scrolling
    // Clear image src after closing to avoid displaying old image next time
    setTimeout(() => {
      lightboxImg.src = '';
      lightboxContent.classList.remove('loaded');
    }, 300);
  }
  
  function showNext() {
    currentIndex = (currentIndex + 1) % images.length;
    updateLightboxContent();
  }
  
  function showPrev() {
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    updateLightboxContent();
  }
  
  function updateLightboxContent() {
    lightboxContent.classList.remove('loaded');
    const imgData = images[currentIndex];
    
    // Set src and wait for load to apply fade-in
    lightboxImg.src = imgData.path;
    
    const countText = `${currentIndex + 1} / ${images.length}`;
    const descText = imgData.caption ? ` - ${imgData.caption}` : '';
    lightboxCaption.textContent = `${countText}${descText}`;
  }
  
  // Image onload handler to trigger animations smoothly
  lightboxImg.addEventListener('load', () => {
    lightboxContent.classList.add('loaded');
  });
  
  // Bind click handlers to gallery items
  galleryItems.forEach(item => {
    item.addEventListener('click', () => {
      const index = parseInt(item.dataset.index, 10);
      openLightbox(index);
    });
  });
  
  // Click event listeners for controls
  lightboxClose.addEventListener('click', closeLightbox);
  lightboxNext.addEventListener('click', (e) => {
    e.stopPropagation();
    showNext();
  });
  lightboxPrev.addEventListener('click', (e) => {
    e.stopPropagation();
    showPrev();
  });
  
  // Click on background closes lightbox
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target === lightboxContent) {
      closeLightbox();
    }
  });
  
  // Keyboard navigation support
  window.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('open')) return;
    
    if (e.key === 'ArrowRight') {
      showNext();
    } else if (e.key === 'ArrowLeft') {
      showPrev();
    } else if (e.key === 'Escape') {
      closeLightbox();
    }
  });
});
</script>

<%- include('../partials/footer') %>
