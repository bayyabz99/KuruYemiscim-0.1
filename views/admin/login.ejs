<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Giriş | Tazeci Panel</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    body.login-page {
      font-family: 'Outfit', 'Inter', system-ui, sans-serif;
      background: radial-gradient(circle at 10% 20%, #FAF5EB 0%, #EADBCE 90%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      position: relative;
      overflow: hidden;
    }

    /* Floating nut/leaf icons for organic aesthetic */
    .bg-decor {
      position: absolute;
      font-size: 2.5rem;
      opacity: 0.15;
      user-select: none;
      pointer-events: none;
      animation: float 8s ease-in-out infinite;
    }
    .bg-decor.d1 { top: 10%; left: 15%; animation-delay: 0s; }
    .bg-decor.d2 { top: 75%; left: 8%; animation-delay: 2s; }
    .bg-decor.d3 { top: 20%; right: 12%; animation-delay: 4s; }
    .bg-decor.d4 { top: 80%; right: 15%; animation-delay: 6s; }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(15deg); }
    }

    .login-card {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(234, 219, 206, 0.6);
      padding: 3rem 2.5rem;
      border-radius: 24px;
      box-shadow: 0 20px 50px rgba(78, 124, 58, 0.08);
      width: min(440px, 100%);
      transition: all 0.3s ease;
      position: relative;
      z-index: 10;
    }

    .login-card:hover {
      box-shadow: 0 30px 60px rgba(78, 124, 58, 0.12);
      transform: translateY(-4px);
    }

    .login-brand-logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin-bottom: 2rem;
    }

    .login-logo-circle {
      width: 64px;
      height: 64px;
      background: var(--admin-primary-bg);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.2rem;
      margin-bottom: 1rem;
      box-shadow: 0 8px 16px rgba(78, 124, 58, 0.1);
    }

    .login-card h1 {
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--admin-text);
      letter-spacing: -0.02em;
      margin-bottom: 0.35rem;
    }

    .login-card p {
      color: var(--admin-muted);
      font-size: 0.95rem;
      margin-bottom: 0;
      font-weight: 500;
    }

    .login-error {
      background: #fef2f2;
      color: #b91c1c;
      padding: 0.85rem 1rem;
      border-radius: 12px;
      margin-bottom: 1.5rem;
      font-size: 0.88rem;
      border: 1px solid #fee2e2;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-group label {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      color: var(--admin-text);
      font-size: 0.9rem;
      margin-bottom: 0.45rem !important;
    }

    .form-group input {
      font-family: 'Inter', sans-serif;
      width: 100%;
      padding: 0.8rem 1rem !important;
      border: 1.5px solid var(--admin-border) !important;
      border-radius: 12px !important;
      background: rgba(255, 255, 255, 0.9) !important;
      transition: all 0.2s ease !important;
      font-size: 0.95rem !important;
      color: var(--admin-text) !important;
    }

    .form-group input:focus {
      outline: none !important;
      border-color: var(--admin-primary) !important;
      background: #ffffff !important;
      box-shadow: 0 0 0 4px var(--admin-primary-bg) !important;
    }

    .btn-admin {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      padding: 0.85rem 1.5rem;
      background: var(--admin-primary);
      color: white;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s ease;
      box-shadow: 0 4px 12px rgba(78, 124, 58, 0.2);
    }

    .btn-admin:hover {
      background: #3c612c;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(78, 124, 58, 0.3);
      opacity: 1;
    }

    .btn-admin:active {
      transform: translateY(0);
    }

    .login-footer-text {
      text-align: center;
      margin-top: 2rem;
      font-size: 0.8rem;
      color: var(--admin-muted);
    }

    .login-footer-text a {
      color: var(--admin-primary);
      text-decoration: none;
      font-weight: 600;
    }
  </style>
</head>
<body class="login-page">
  <!-- Decorative background elements -->
  <span class="bg-decor d1">🥜</span>
  <span class="bg-decor d2">🍎</span>
  <span class="bg-decor d3">🌿</span>
  <span class="bg-decor d4">☕</span>

  <div class="login-card">
    <div class="login-brand-logo">
      <div class="login-logo-circle">🥜</div>
      <h1>TAZECİ PANEL</h1>
      <p>Kuruyemiş & Organik Yönetim Paneli</p>
    </div>

    <div class="login-error" id="loginError" style="display:none"></div>

    <form id="loginForm" class="form-admin" autocomplete="off" data-redirect="<%= redirect %>">
      <div class="form-group">
        <label for="username">Kullanıcı Adı *</label>
        <input type="text" id="username" name="username" required autocomplete="off" minlength="3" placeholder="Kullanıcı adınız">
      </div>
      <div class="form-group" style="margin-bottom: 2rem;">
        <label for="password">Şifre *</label>
        <input type="password" id="password" name="password" required autocomplete="off" placeholder="Şifreniz">
      </div>
      <button type="submit" class="btn-admin" style="width:100%">Giriş Yap</button>
    </form>

    <div class="login-footer-text">
      <a href="/">← Siteye Geri Dön</a>
    </div>
  </div>
  <script src="/js/admin-login.js"></script>
</body>
</html>
