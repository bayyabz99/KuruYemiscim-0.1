<%- include('../partials/header') %>

<div class="container page-card reveal" id="cartPage">
  <h1 style="margin-bottom:0.25rem; font-weight: 800;">🛒 Sepetim</h1>
  <p style="color: var(--text-muted); margin-bottom: 2rem; font-size: 0.92rem;">Eklediğiniz doğal lezzetleri kontrol edip sipariş adımına geçebilirsiniz.</p>

  <!-- Kargo Progress Bar -->
  <div class="kargo-progress-container" id="kargoProgressContainer" data-threshold="<%= settings?.free_shipping_threshold || 500 %>" style="display:none">
    <div class="kargo-progress-text">
      <span id="kargoProgressMessage">Ücretsiz kargo avantajı için <strong>0,00 ₺</strong> kaldı!</span>
      <span id="kargoProgressPercent" style="font-weight: 700;">0%</span>
    </div>
    <div class="kargo-progress-bar-bg">
      <div class="kargo-progress-bar-fill" id="kargoProgressBarFill"></div>
    </div>
  </div>

  <div id="cartItems" class="reveal stagger-1"></div>
  
  <div id="cartSummary" class="cart-summary reveal stagger-2" style="display:none">
    <div class="trust-inline" style="margin-bottom: 2rem; justify-content: center; border-color: rgba(78, 124, 58, 0.15);">
      <span class="trust-inline-item">🌿 %100 Katkısız</span>
      <span class="trust-inline-item">🔒 Güvenli Sipariş</span>
      <span class="trust-inline-item">✨ Tazelik Garantisi</span>
    </div>
    <p class="cart-summary-total">Sepet Toplamı: <strong id="cartTotal">0,00 ₺</strong></p>
    <a href="/odeme" class="btn btn-primary btn-block" style="font-size: 1rem; padding: 1rem;">Siparişi Tamamla (DB Kayıtlı)</a>
    <button type="button" id="btnWhatsappCheckout" class="btn btn-whatsapp btn-block" style="margin-top: 0.65rem; font-size: 1rem; padding: 1rem;" data-phone="<%= settings?.contact_whatsapp %>">
      🟢 WhatsApp ile Hızlı Sipariş Ver
    </button>
    <button type="button" id="btnClearCart" class="btn btn-ghost btn-block cart-clear-btn">Sepeti Tamamen Temizle</button>
  </div>
</div>

<script src="/js/cart-page.js"></script>
<%- include('../partials/footer') %>
