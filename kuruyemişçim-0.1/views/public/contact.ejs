<%- include('../partials/header') %>

<section>
  <div class="container" style="max-width:700px;padding:2rem 0 4rem">
    <h1 class="section-title" style="text-align:center;">İletişim</h1>
    <p class="section-sub" style="text-align:center;">Sipariş ve sorularınız için bize ulaşın</p>
    <div class="page-card">
      <div style="display: grid; gap: 1.25rem;">
        <div style="display:flex; align-items:center; gap:0.75rem; padding: 1rem; background: var(--bg-warm); border-radius: var(--radius-sm);">
          <span style="font-size:1.5rem;">📍</span>
          <div>
            <strong style="font-size: 0.85rem; color: var(--text-muted);">Adres</strong>
            <p style="font-weight:500; color: var(--earth);"><%= settings?.contact_address || 'Türkiye' %></p>
          </div>
        </div>
        <div style="display:flex; align-items:center; gap:0.75rem; padding: 1rem; background: var(--bg-warm); border-radius: var(--radius-sm);">
          <span style="font-size:1.5rem;">📞</span>
          <div>
            <strong style="font-size: 0.85rem; color: var(--text-muted);">Telefon</strong>
            <p><a href="tel:<%= settings?.contact_phone %>" style="font-weight:500; color: var(--earth);"><%= settings?.contact_phone || '' %></a></p>
          </div>
        </div>
        <% if (settings?.contact_email) { %>
        <div style="display:flex; align-items:center; gap:0.75rem; padding: 1rem; background: var(--bg-warm); border-radius: var(--radius-sm);">
          <span style="font-size:1.5rem;">✉️</span>
          <div>
            <strong style="font-size: 0.85rem; color: var(--text-muted);">E-posta</strong>
            <p><a href="mailto:<%= settings.contact_email %>" style="font-weight:500; color: var(--earth);"><%= settings.contact_email %></a></p>
          </div>
        </div>
        <% } %>
        <% if (settings?.instagram_url) { %>
        <div style="display:flex; align-items:center; gap:0.75rem; padding: 1rem; background: var(--bg-warm); border-radius: var(--radius-sm);">
          <span style="font-size:1.5rem;">📸</span>
          <div>
            <strong style="font-size: 0.85rem; color: var(--text-muted);">Instagram</strong>
            <p><a href="<%= settings.instagram_url %>" target="_blank" rel="noopener" style="font-weight:500; color: var(--earth);">Bizi takip edin</a></p>
          </div>
        </div>
        <% } %>
      </div>
      <div style="margin-top: 1.75rem; text-align:center;">
        <a href="https://wa.me/<%= settings?.contact_whatsapp %>" class="btn btn-whatsapp" target="_blank" rel="noopener">WhatsApp ile Sipariş Ver</a>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
