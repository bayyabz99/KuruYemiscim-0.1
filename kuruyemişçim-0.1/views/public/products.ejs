<%- include('../partials/header') %>

<%
  const categoryEmojis = {
    'kuruyemis': '🥜',
    'kuru-meyve': '🍎',
    'organik-urunler': '🌿',
    'lokum-sekerleme': '🍬',
    'kahve-cay': '☕',
    'baharatlar': '🌶️',
    'yaglar-soslar': '🍯',
    'ballar-receller': '🐝',
    'draje-cikolata': '🍫',
    'bitkisel-urunler': '🌱'
  };
  function getEmoji(slug) {
    return categoryEmojis[slug.toLowerCase()] || '✨';
  }
%>

<div class="container shop-layout">
  <button type="button" class="mobile-filter-btn" id="filterToggle" aria-expanded="false">☰ Filtreler ve Sıralama</button>

  <aside class="sidebar-panel reveal" id="shopSidebar">
    <h3>Kategoriler</h3>
    <input type="text" class="filter-search" id="categorySearch" placeholder="Kategori ara...">
    <ul class="filter-list" id="categoryList">
      <li>
        <label>
          <input type="radio" name="kategori" value="tumu" form="filterForm" <%= filters.kategori === 'tumu' ? 'checked' : '' %>>
          🌈 Tümü
        </label>
      </li>
      <% categories.forEach(function(c) { %>
        <li data-name="<%= c.name.toLowerCase() %>">
          <label>
            <input type="radio" name="kategori" value="<%= c.slug %>" form="filterForm" <%= filters.kategori === c.slug ? 'checked' : '' %>>
            <%= getEmoji(c.slug) %> <%= c.name %>
          </label>
        </li>
      <% }) %>
    </ul>

    <div class="filter-section">
      <h3>Dinamik Filtreler</h3>
      <ul class="filter-list">
        <li><label><input type="checkbox" name="indirimli" value="1" form="filterForm" <%= filters.indirimli ? 'checked' : '' %>> 🏷️ İndirimli Ürünler</label></li>
        <li><label><input type="checkbox" name="ucretsiz_kargo" value="1" form="filterForm" <%= filters.ucretsiz_kargo ? 'checked' : '' %>> 🚚 Ücretsiz Kargo</label></li>
        <li><label><input type="checkbox" name="stokta" value="1" form="filterForm" <%= filters.stokta ? 'checked' : '' %>> ✔ Stokta Olanlar</label></li>
      </ul>
    </div>
  </aside>

  <div class="shop-main">
    <form id="filterForm" method="get" action="/urunler" class="reveal stagger-1">
      <div class="shop-header">
        <h1>Doğal Lezzet Marketi</h1>

        <!-- Horizontal category strip -->
        <div class="category-strip" id="categoryStrip">
          <button type="button" class="category-chip <%= filters.kategori === 'tumu' ? 'active' : '' %>" data-slug="tumu">🌈 Tümü</button>
          <% categories.forEach(function(c) { %>
            <button type="button" class="category-chip <%= filters.kategori === c.slug ? 'active' : '' %>" data-slug="<%= c.slug %>"><%= getEmoji(c.slug) %> <%= c.name %></button>
          <% }) %>
        </div>

        <div class="shop-toolbar">
          <div class="product-search-wrap">
            <input type="search" name="ara" class="product-search-input" value="<%= filters.ara %>" placeholder="Taze ürün ara..." aria-label="Ürün ara">
            <button type="submit" class="product-search-btn" aria-label="Ara">Ara</button>
          </div>
          <select name="sirala" class="sort-select" aria-label="Sıralama">
            <option value="popular" <%= filters.sirala === 'popular' ? 'selected' : '' %>>🔥 En Popüler</option>
            <option value="newest" <%= filters.sirala === 'newest' ? 'selected' : '' %>>📅 En Yeni</option>
            <option value="price_asc" <%= filters.sirala === 'price_asc' ? 'selected' : '' %>>💰 Fiyat: Düşükten Yükseğe</option>
            <option value="price_desc" <%= filters.sirala === 'price_desc' ? 'selected' : '' %>>💰 Fiyat: Yüksekten Düşüğe</option>
            <option value="name" <%= filters.sirala === 'name' ? 'selected' : '' %>>🔤 Harf Sırasına Göre</option>
          </select>
        </div>
      </div>
      <% if (filters.ara) { %>
        <p class="search-result-hint"><%= products.length %> sonuç bulundu: "<strong><%= filters.ara %></strong>" <a href="/urunler">aramayı temizle</a></p>
      <% } %>
    </form>

    <% if (products.length === 0) { %>
      <div class="empty-state reveal stagger-2">
        <p style="font-size:3.5rem; margin-bottom:1rem; animation: logoFloat 4s ease-in-out infinite;">🥜</p>
        <p style="font-weight: 600;">Bu filtrelere uygun taze ürün bulunamadı.</p>
        <a href="/urunler" class="btn btn-primary" style="margin-top:1.5rem">Filtreleri Temizle</a>
      </div>
    <% } else { %>
      <div class="product-grid reveal stagger-2" id="productGrid">
        <% products.forEach(function(p, index) { %>
          <article class="product-card" style="animation: fadeIn 0.5s var(--ease) both; animation-delay: <%= index * 0.04 %>s;">
            <a href="/urun/<%= p.slug %>">
              <div class="product-card-image">
                <% if (p.discount_percent > 0) { %><span class="badge-discount">%<%= p.discount_percent %> İndirim</span><% } %>
                <% if (p.stock <= 0) { %><span class="badge-soldout">TÜKENDİ</span><% } %>
                <% if (p.image_path) { %>
                  <img src="<%= p.image_path %>" alt="<%= p.title %>" loading="lazy">
                <% } else { %>
                  <div class="product-placeholder">🥜</div>
                <% } %>
              </div>
              <div class="product-card-body">
                <h3 class="product-card-title"><%= p.title %></h3>
                <div class="product-price">
                  <span class="price-current"><%= formatPrice(p.sale_price || p.price) %></span>
                  <% if (p.sale_price) { %><span class="price-old"><%= formatPrice(p.price) %></span><% } %>
                  <span class="price-unit">/ kg</span>
                </div>
              </div>
            </a>
            <div class="product-card-body product-card-actions">
              <button type="button" class="btn-add" data-add-cart="<%= p.id %>" data-title="<%= p.title %>" data-price="<%= p.sale_price || p.price %>" data-slug="<%= p.slug %>" <%= p.stock <= 0 ? 'disabled' : '' %>>
                <%= p.stock <= 0 ? 'Tükendi' : '🛒 Sepete Ekle' %>
              </button>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<div class="sidebar-overlay" id="shopSidebarOverlay"></div>

<script>
// Category search in sidebar
document.getElementById('categorySearch')?.addEventListener('input', function(e) {
  const q = e.target.value.toLowerCase();
  document.querySelectorAll('#categoryList li[data-name]').forEach(li => {
    li.style.display = li.dataset.name.includes(q) ? '' : 'none';
  });
});

const filterForm = document.getElementById('filterForm');

// Sidebar radio/checkbox → submit form
document.querySelectorAll(
  '#filterForm input[type="radio"], #filterForm input[type="checkbox"], [form="filterForm"][type="radio"], [form="filterForm"][type="checkbox"]'
).forEach(el => {
  el.addEventListener('change', () => {
    filterForm.submit();
    closeShopSidebar();
  });
});
filterForm?.querySelector('.sort-select')?.addEventListener('change', () => filterForm.submit());

// Category strip chips → AJAX filter
document.querySelectorAll('#categoryStrip .category-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    const slug = chip.dataset.slug;
    // Update hidden radio
    const radio = document.querySelector(`[form="filterForm"][name="kategori"][value="${slug}"]`) ||
                  document.querySelector(`#filterForm [name="kategori"][value="${slug}"]`);
    if (radio) { radio.checked = true; }
    // Update visual
    document.querySelectorAll('#categoryStrip .category-chip').forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    // Fetch filtered products via API
    fetchFilteredProducts(slug);
  });
});

function showShimmer() {
  const grid = document.getElementById('productGrid');
  if (!grid) return;
  
  grid.innerHTML = Array(8).fill(0).map(() => `
    <div class="product-card shimmer" style="height: 380px; border-color: transparent;">
      <div style="aspect-ratio:1; background: rgba(32, 18, 11, 0.03);"></div>
      <div style="padding:1.25rem; display:flex; flex-direction:column; gap:0.5rem; flex-grow:1;">
        <div style="height:1.2rem; background:rgba(32, 18, 11, 0.05); border-radius:6px; width:85%;"></div>
        <div style="height:0.8rem; background:rgba(32, 18, 11, 0.03); border-radius:6px; width:50%;"></div>
        <div style="height:1.5rem; background:rgba(32, 18, 11, 0.05); border-radius:6px; width:40%; margin-top:auto;"></div>
        <div style="height:2.2rem; background:rgba(32, 18, 11, 0.03); border-radius:6px; margin-top:0.5rem;"></div>
      </div>
    </div>
  `).join('');
}

async function fetchFilteredProducts(categorySlug) {
  try {
    showShimmer();
    const params = new URLSearchParams();
    if (categorySlug && categorySlug !== 'tumu') params.set('category', categorySlug);
    const searchInput = filterForm?.querySelector('[name="ara"]');
    if (searchInput?.value) params.set('q', searchInput.value);
    const sortSelect = filterForm?.querySelector('[name="sirala"]');
    if (sortSelect?.value) params.set('sort', sortSelect.value);

    // Get checked checkboxes from sidebar
    const checkboxes = ['indirimli', 'ucretsiz_kargo', 'stokta'];
    checkboxes.forEach(name => {
      const cb = document.querySelector(`[form="filterForm"][name="${name}"]:checked`) ||
                 document.querySelector(`#filterForm [name="${name}"]:checked`);
      if (cb) params.set(name, '1');
    });

    const res = await fetch('/api/products?' + params.toString());
    const products = await res.json();
    renderProductGrid(products);
  } catch (err) {
    console.error('Filter error:', err);
  }
}

function renderProductGrid(products) {
  const grid = document.getElementById('productGrid');
  if (!grid) return;

  if (!products.length) {
    grid.innerHTML = `
      <div class="empty-state" style="grid-column:1/-1">
        <p style="font-size:3.5rem;margin-bottom:1rem; animation: logoFloat 4s ease-in-out infinite;">🥜</p>
        <p style="font-weight: 600;">Bu filtrelere uygun taze ürün bulunamadı.</p>
      </div>`;
    return;
  }

  grid.innerHTML = products.map((p, index) => {
    const price = p.sale_price || p.price;
    const priceFormatted = new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(price);
    const oldPriceFormatted = p.sale_price ? new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(p.price) : '';
    const imgHtml = p.image_path
      ? `<img src="${p.image_path}" alt="${p.title}" loading="lazy">`
      : `<div class="product-placeholder">🥜</div>`;

    return `
      <article class="product-card" style="animation: fadeIn 0.5s var(--ease) both; animation-delay: ${index * 0.04}s;">
        <a href="/urun/${p.slug}">
          <div class="product-card-image">
            ${p.discount_percent > 0 ? `<span class="badge-discount">%${p.discount_percent} İndirim</span>` : ''}
            ${p.stock <= 0 ? '<span class="badge-soldout">TÜKENDİ</span>' : ''}
            ${imgHtml}
          </div>
          <div class="product-card-body">
            <h3 class="product-card-title">${p.title}</h3>
            <div class="product-price">
              <span class="price-current">${priceFormatted}</span>
              ${p.sale_price ? `<span class="price-old">${oldPriceFormatted}</span>` : ''}
              <span class="price-unit">/ kg</span>
            </div>
          </div>
        </a>
        <div class="product-card-body product-card-actions">
          <button type="button" class="btn-add" data-add-cart="${p.id}" data-title="${p.title}" data-price="${price}" data-slug="${p.slug}" ${p.stock <= 0 ? 'disabled' : ''}>
            ${p.stock <= 0 ? 'Tükendi' : '🛒 Sepete Ekle'}
          </button>
        </div>
      </article>`;
  }).join('');

  // Re-bind add-to-cart buttons
  if (typeof Cart !== 'undefined') {
    grid.querySelectorAll('[data-add-cart]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (btn.disabled) return;
        Cart.add({
          product_id: +btn.dataset.addCart,
          title: btn.dataset.title,
          price: +btn.dataset.price,
          slug: btn.dataset.slug,
          quantity: 1,
          selected_color: null,
        });
        const orig = btn.textContent;
        btn.textContent = '✓ Eklendi';
        setTimeout(() => { btn.textContent = orig; }, 1200);
      });
    });
  }
}

// Mobile sidebar
const filterToggle = document.getElementById('filterToggle');
const shopSidebar = document.getElementById('shopSidebar');
const shopOverlay = document.getElementById('shopSidebarOverlay');

function closeShopSidebar() {
  shopSidebar?.classList.remove('open');
  shopOverlay?.classList.remove('visible');
  filterToggle?.setAttribute('aria-expanded', 'false');
}

filterToggle?.addEventListener('click', () => {
  const open = shopSidebar?.classList.toggle('open');
  shopOverlay?.classList.toggle('visible', open);
  filterToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
});
shopOverlay?.addEventListener('click', closeShopSidebar);
</script>

<%- include('../partials/footer') %>
